{
  "name": "Leaky Bucket Inn",
  "pages": [
    {
      "name": "[L1] Taproom",
      "type": "text",
      "text": {
        "content": "<p>Sersyl works the taproom with her youngest son Harden (age 11). The taproom is noisy but cozy. Sersyl will not tolerate drunks and anyone who is asked to leave is never allowed back in – ever.</p>",
        "format": 1
      },
