    },
    {
      "name": "[L5] Family Quarters",
      "type": "text",
      "text": {
        "content": "<p>Sersyl and her husband share this bed and their daughter sleeps on a pallet by the door. Their son stays in the kitchen.</p>",
        "format": 1
      },
