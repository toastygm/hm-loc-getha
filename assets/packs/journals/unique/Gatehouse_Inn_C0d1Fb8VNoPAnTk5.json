    },
    {
      "name": "[G8] Guest Rooms",
      "type": "text",
      "text": {
        "content": "<p>Guest rooms are on the second floor. The best rooms face the river. The second class rooms face the square and overlook the kitchen’s courtyard.</p>",
        "format": 1
      },
